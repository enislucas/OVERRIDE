# OVERRIDE runtime / session state (created while an alarm is running)
session.*
UNLOCK
PANIC
arm.log
probe.ok
*.bak

# v3/v4 user state (created/imported by the panel; the alarm lives in the Windows task, not here)
v3/config.json
v4/config.json

# user-supplied audio (may be copyrighted). The built-in sounds live in sounds/
# and can be regenerated any time with make_sounds.ps1
alarm.mp3

# OS / editor cruft
Thumbs.db
desktop.ini
.vscode/
